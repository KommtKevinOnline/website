# Postgres (shared with kko-worker)
NUXT_DATABASE_URL="postgres://user:password@localhost:5432/kko"

# Twitch app credentials (stream status, user lookup)
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""

# Session encryption (nuxt-auth-utils), min. 32 chars
NUXT_SESSION_PASSWORD=""

# Twitch OAuth login for /admin
NUXT_OAUTH_TWITCH_CLIENT_ID=""
NUXT_OAUTH_TWITCH_CLIENT_SECRET=""
NUXT_OAUTH_TWITCH_REDIRECT_URL="https://kommtkevinonline.de/auth/twitch"

# Comma-separated Twitch user ids that own the site (can manage mods)
NUXT_ADMIN_TWITCH_IDS=""
